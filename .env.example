OPENROUTER_API_KEY=sk-or-v1-...
# Gemini 3.1 Flash Lite — fastest model on this workload (~1.9s/batch),
# moved off 2.5 Flash ahead of Google's announced deprecation. DeepSeek V3.1
# stays as fallback (proven reliable + stricter on exclusion clauses).
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview-20260303
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat-v3.1

# Discord DM notifications (preferred — bot sends you a DM directly)
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# Discord webhook notifications (alternative — posts to a channel)
DISCORD_WEBHOOK_URL=

LOG_LEVEL=info
HEADLESS=true
SCRAPE_DELAY_MIN=2000
SCRAPE_DELAY_MAX=5000
