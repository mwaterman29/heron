OPENROUTER_API_KEY=sk-or-v1-...
# Gemini 2.5 Flash benchmarked ~13x faster and ~6x cheaper than DeepSeek V3.1
# on listing evaluation, with equal-or-better judgment on marginal calls.
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat-v3.1

# Discord DM notifications (preferred — bot sends you a DM directly)
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# Discord webhook notifications (alternative — posts to a channel)
DISCORD_WEBHOOK_URL=

LOG_LEVEL=info
HEADLESS=true
SCRAPE_DELAY_MIN=2000
SCRAPE_DELAY_MAX=5000
