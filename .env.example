OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1
OPENROUTER_FALLBACK_MODEL=z-ai/glm-4.7-flash

# Discord DM notifications (preferred — bot sends you a DM directly)
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# Discord webhook notifications (alternative — posts to a channel)
DISCORD_WEBHOOK_URL=

LOG_LEVEL=info
HEADLESS=true
SCRAPE_DELAY_MIN=2000
SCRAPE_DELAY_MAX=5000
